# ========================
# WireGuard - SENSITIVE
# ========================
*.key
*.priv
*.pem
*.pub
presharedkey
wg0.conf
wg1.conf

# ========================
# ldown - SENSITIVE
# ========================
keys/*
!keys/.gitkeep
logs/*
!logs/.gitkeep
conf/ldown.conf


# runtime state — never commit
/etc/ldown/
*.private.key
*.key
*.enc
*.tar.gz
*.tar.gz.enc

# locks + logs
/var/lock/ldown*
/var/log/ldown/

# ========================
# Configs - keep examples/defaults
# ========================
!conf/ldown.conf.example
!conf/defaults.conf 
